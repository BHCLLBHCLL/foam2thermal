  "boundary_conditions": {
    "air": {
      "T": {
        "open": { "type": "inletOutlet", "inletValue": "uniform 300", "value": "uniform 300" }
      },
      "U": {
        "open": { "type": "pressureInletOutletVelocity", "value": "uniform (0 0 0)" }
      },
      "p_rgh": {
        "open": { "type": "fixedValue", "value": "uniform 101325" }
      }
    },
    "CPU": {
      "T": {
        "CPU_s": {
          "type": "externalWallHeatFluxTemperature",
          "mode": "power",
          "Q": "uniform 20",
          "kappaMethod": "solidThermo",
          "value": "uniform 300"
        }
      }
    },
    "Cu": {
      "T": {
        "CU_s": {
          "type": "externalWallHeatFluxTemperature",
          "mode": "power",
          "Q": "uniform 15",
          "kappaMethod": "solidThermo",
          "value": "uniform 300"
        }
      }
    }
