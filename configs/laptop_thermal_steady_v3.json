    "relaxation": {
      "p_rgh": 0.3,
      "U": 0.5,
      "h": 0.5
    }
  },

  "mesh_prep": {
    "coalesce_interfaces": false,
    "coalesce_point_tol": 1.0e-4,
    "coalesce_geometric_fallback": false,
    "coalesce_geom_tol": 5.0e-4,
    "stitch_interfaces": false,
    "stitch_mode": "partial",
    "stitch_integral_ratio_max": 1.05,
    "stitch_partial_ratio_max": 3.0,
    "coalesce_exclude_patterns": ["ami_rot"],
    "create_ami_patches": true,
    "stitch_tolerance": {
      "pointMergeTol": 0.1,
      "edgeMergeTol": 0.05
