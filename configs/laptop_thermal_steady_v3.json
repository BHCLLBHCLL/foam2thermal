  "turbulence": { "simulationType": "laminar" },
  "gravity": [0, 0, -9.81],

  "numerics": {
    "endTime": 100,
    "writeInterval": 50,
    "deltaT": 1,
    "nNonOrthogonalCorrectors": 1,
    "momentumPredictor": false,
    "frozenFlow": false,
    "pRefValue": 101325,
    "rhoMin": 0.05,
    "rhoMax": 10.0,
    "limitTemperature": {
      "min": 200,
      "max": 2000
