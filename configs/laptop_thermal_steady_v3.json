  "interfaces": {
    "auto_scan": true,
    "ami_patterns": ["ami_rot\\d+"],
    "ami_rotation_axis": [0, 0, 1],
    "explicit": [
      { "master": "ami_rot1", "slave": "ami_rot1_1", "method": "cyclicAMI" },
      { "master": "ami_rot2", "slave": "ami_rot2_1", "method": "cyclicAMI" }
    ]
  },

  "patch_regions": {
    "open": "air",
    "ami_rot1": "air",
    "ami_rot1_1": "air",
    "ami_rot2": "air",
    "ami_rot2_1": "air",
    "impeller1_s": "air",
    "impeller2_s": "air",
    "case1_s": "case1",
    "case1_s_1": "air",
    "case2_s": "case2",
    "case2_s_1": "air",
    "CPU_s": "CPU",
    "CPU_s_1": "air",
    "CU_s": "Cu",
    "CU_s_1": "air",
    "Cover_s": "Cover",
