        "equationOfState": { "rho": 2719 }
      }
    },
    "silicon": {
      "thermoType": {
        "type": "heSolidThermo",
        "mixture": "pureMixture",
        "transport": "constIso",
        "thermo": "hConst",
        "equationOfState": "rhoConst",
        "specie": "specie",
        "energy": "sensibleEnthalpy"
      },
      "mixture": {
